# Qwen Embedding Service Configuration

# Model configuration
MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
DEVICE=  # auto-detect: cuda, cpu, mps, or leave empty for auto
NORMALIZE_EMBEDDINGS=true
BATCH_SIZE=32

# HuggingFace cache (model downloads will be stored here)
# HF_HOME=~/.cache/huggingface

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Logging
LOG_LEVEL=info
