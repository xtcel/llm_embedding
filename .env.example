# Qwen Embedding Service Configuration

# Model configuration
# LOCAL_MODEL_PATH takes priority: if set and the directory exists, the model is
# loaded from disk without any network access. Leave empty to download from HuggingFace.
# LOCAL_MODEL_PATH=~/models/Qwen3-Embedding-0.6B

MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
# auto-detect: cuda, cpu, mps, or leave empty for auto
DEVICE=
NORMALIZE_EMBEDDINGS=true
BATCH_SIZE=32

# HuggingFace cache (model downloads will be stored here)
# HF_HOME=~/.cache/huggingface

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Logging
LOG_LEVEL=info
